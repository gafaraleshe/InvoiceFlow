# ─────────────────────────────────────────────────────────────────────────────
# InvoiceFlow — environment variables
# Copy to `.env` for local dev and paste into Vercel → Settings → Env Vars for prod.
# See docs/SETUP_GUIDE.md for where each value comes from. NEVER commit a real .env.
# Variables prefixed VITE_ are exposed to the browser — keep secrets OUT of those.
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000
CRON_SECRET=                      # long random string; gates /api/jobs/*

# ── Supabase (database + auth + storage) ────────────────────────────────────
# NOTE: If you used Vercel's Supabase integration, these are auto-provisioned in
# Vercel under the names POSTGRES_URL (pooled), POSTGRES_URL_NON_POOLING (direct),
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_JWT_SECRET.
# The server reads either naming. For the browser you must add the VITE_ ones.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=        # server only — full access, never in browser
SUPABASE_JWT_SECRET=              # verifies user access tokens on the API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=           # safe for the browser (RLS protects data)
# Postgres connection (Supabase → Database → Connection string)
DATABASE_URL=                     # pooled (Transaction mode) — runtime  (= POSTGRES_URL)
DIRECT_URL=                       # direct (non-pooled) — migrations only (= POSTGRES_URL_NON_POOLING)

# ── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=billing@yourdomain.com

# ── Polar.sh (SaaS subscriptions) ───────────────────────────────────────────
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox              # sandbox | production
# Product/price IDs for the three tiers (from Polar)
POLAR_PRODUCTS_JSON={"pro_monthly":"","pro_annual":"","business_monthly":"","business_annual":""}

# ── Stripe (invoice payments) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# ── Observability (optional) ────────────────────────────────────────────────
SENTRY_DSN=
VITE_SENTRY_DSN=

# ── Storage ─────────────────────────────────────────────────────────────────
SUPABASE_STORAGE_BUCKET=invoices
